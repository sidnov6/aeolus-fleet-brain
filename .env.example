# AEOLUS — LLM provider key (optional). Copy to .env and fill ONE of these.
# Without a key the agents run with a deterministic reasoning fallback; the
# moment a key is present the LangGraph agents switch to the real model.

# Google Gemini (free tier — https://aistudio.google.com/apikey)
# GEMINI_API_KEY=...

# Groq (free tier — https://console.groq.com/keys)
# GROQ_API_KEY=...

# Anthropic (requires billing)
# ANTHROPIC_API_KEY=...

# Override the auto-selected model if you like:
# AEOLUS_LLM_MODEL=gemini/gemini-2.0-flash

# Optional: ENTSO-E day-ahead prices (free token — https://transparency.entsoe.eu/).
# If unset, AEOLUS uses energy-charts.info (real DE-LU prices, no key needed).
# ENTSOE_API_TOKEN=...
